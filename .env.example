# .env.example — Dossier Project
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.
#
# Keys are grouped by which Step/Agent needs them.
# You do NOT need all keys upfront — add them as you build each step.

# =============================================================================
# STEP 00 — Project Setup (needed immediately)
# =============================================================================

# OpenAI — primary LLM for most agents (job scoring, gap analysis, etc.)
OPENAI_API_KEY=

# Anthropic — used only by Resume Agent + Cover Letter (LaTeX precision tasks)
ANTHROPIC_API_KEY=

# =============================================================================
# STEP 01 — Persona Builder (needed when building Step 1)
# =============================================================================

# GitHub username — optional, used to pull public repo data into your profile
GITHUB_USERNAME=

# =============================================================================
# STEP 02 — Job Discovery (needed when building Step 2)
# =============================================================================

# JSearch API (RapidAPI) — primary job search API
# Sign up at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# Adzuna — secondary job source, wider India coverage
# Sign up at: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# =============================================================================
# STEP 02 — Notifications (Telegram bot for URGENT alerts + approvals)
# =============================================================================

# Create a bot via @BotFather on Telegram, get the token
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID (send /start to your bot, then check getUpdates)
TELEGRAM_CHAT_ID=

# =============================================================================
# STEP 03 — Tracker (Google Sheets live dashboard)
# =============================================================================

# Path to your Google service account credentials JSON file
# Guide: https://docs.gspread.org/en/latest/oauth2.html#for-bots-using-service-account
GOOGLE_SHEETS_CREDENTIALS_JSON=

# The ID of your Google Spreadsheet (from the URL: /spreadsheets/d/THIS_PART/edit)
GOOGLE_SPREADSHEET_ID=

# =============================================================================
# STEP 09+ — Gmail Reader (closes the loop on recruiter replies)
# =============================================================================

# Path to your Gmail OAuth2 credentials JSON file
# Guide: https://developers.google.com/gmail/api/quickstart/python
GMAIL_CREDENTIALS_JSON=

# =============================================================================
# App Settings — defaults that work out of the box, change if needed
# =============================================================================

# Log level: DEBUG shows everything, INFO shows normal flow, WARNING and above = problems only
LOG_LEVEL=INFO

# Path to the user profile JSON (source of truth for all agents)
PROFILE_PATH=profile/profile.json
